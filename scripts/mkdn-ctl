#!/usr/bin/env python3
"""Minimal CLI to drive mkdn via its test harness socket."""
import json
import socket
import sys
import glob
import os

def find_socket():
    socks = glob.glob("/tmp/mkdn-test-harness-*.sock")
    return sorted(socks, key=os.path.getmtime, reverse=True)[0] if socks else None

def send(sock_path, cmd):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(30)
    s.connect(sock_path)
    s.sendall((json.dumps(cmd) + "\n").encode())
    data = b""
    while b"\n" not in data:
        chunk = s.recv(4096)
        if not chunk:
            break
        data += chunk
    s.close()
    return json.loads(data.decode().strip())

def main():
    if len(sys.argv) < 2:
        print("Usage: mkdn-ctl <command> [args]")
        print("Commands: ping, load <path>, capture [path], scroll <y>,")
        print("          theme <name>, cycle, info, open-timings, resize <w> <h>,")
        print("          recreate-view, press-button <title> [index], ax-tree [depth],")
        print("          ax-press <query> [action] [index], quit")
        sys.exit(1)

    sock = os.environ.get("MKDN_SOCK") or find_socket()
    if not sock:
        print("No harness socket found. Launch mkdn with --test-harness", file=sys.stderr)
        sys.exit(1)

    cmd_name = sys.argv[1]
    try:
        if cmd_name == "ping":
            r = send(sock, {"ping": {}})
        elif cmd_name == "load":
            r = send(sock, {"loadFile": {"path": os.path.abspath(sys.argv[2])}})
        elif cmd_name == "capture":
            path = sys.argv[2] if len(sys.argv) > 2 else "/tmp/mkdn-capture.png"
            r = send(sock, {"captureWindow": {"outputPath": os.path.abspath(path)}})
        elif cmd_name == "scroll":
            r = send(sock, {"scrollTo": {"yOffset": float(sys.argv[2])}})
        elif cmd_name == "theme":
            r = send(sock, {"setTheme": {"theme": sys.argv[2]}})
        elif cmd_name == "cycle":
            r = send(sock, {"cycleTheme": {}})
        elif cmd_name == "info":
            r = send(sock, {"getWindowInfo": {}})
        elif cmd_name == "open-timings":
            r = send(sock, {"getOpenTimings": {}})
        elif cmd_name == "setSidebarWidth":
            r = send(sock, {"setSidebarWidth": {"width": float(sys.argv[2])}})
        elif cmd_name == "toggleSidebar":
            r = send(sock, {"toggleSidebar": {}})
        elif cmd_name == "begin-capture":
            fps = int(sys.argv[2]) if len(sys.argv) > 2 else 60
            out = sys.argv[3] if len(sys.argv) > 3 else "/tmp/mkdn-frames"
            r = send(sock, {"startQuickCapture": {"fps": fps, "outputDir": os.path.abspath(out)}})
        elif cmd_name == "end-capture":
            r = send(sock, {"stopQuickCapture": {}})
        elif cmd_name == "simulate-scroll":
            delta = float(sys.argv[2]) if len(sys.argv) > 2 else -200
            dur = float(sys.argv[3]) if len(sys.argv) > 3 else 0.8
            r = send(sock, {"simulateScroll": {"deltaY": delta, "duration": dur}})
        elif cmd_name == "scroll-sidebar":
            r = send(sock, {"scrollSidebar": {"yOffset": float(sys.argv[2])}})
        elif cmd_name == "resize":
            r = send(sock, {"resizeWindow": {"width": float(sys.argv[2]), "height": float(sys.argv[3])}})
        elif cmd_name == "capture-region":
            x, y, w, h = float(sys.argv[2]), float(sys.argv[3]), float(sys.argv[4]), float(sys.argv[5])
            path = sys.argv[6] if len(sys.argv) > 6 else "/tmp/mkdn-region.png"
            r = send(sock, {"captureRegion": {"region": {"x": x, "y": y, "width": w, "height": h}, "outputPath": os.path.abspath(path)}})
        elif cmd_name == "recreate-view":
            r = send(sock, {"recreateView": {}})
        elif cmd_name == "add-comment":
            body = sys.argv[3] if len(sys.argv) > 3 else "test comment"
            r = send(sock, {"addComment": {"substring": sys.argv[2], "body": body}})
        elif cmd_name == "paste-comment":
            text = sys.argv[3] if len(sys.argv) > 3 else "pasted comment"
            r = send(sock, {"pasteComment": {"substring": sys.argv[2], "text": text}})
        elif cmd_name == "toggle-comments":
            r = send(sock, {"toggleCommentSidebar": {}})
        elif cmd_name == "toggle-minimap":
            r = send(sock, {"toggleMinimap": {}})
        elif cmd_name == "jump-first-comment":
            r = send(sock, {"jumpFirstComment": {}})
        elif cmd_name == "jump-comment-at":
            r = send(sock, {"jumpCommentAt": {"index": int(sys.argv[2])}})
        elif cmd_name == "diagnose-click":
            r = send(sock, {"diagnoseCommentClick": {"index": int(sys.argv[2])}})
        elif cmd_name == "click":
            cmd = {"clickAt": {"x": float(sys.argv[2]), "y": float(sys.argv[3])}}
            if len(sys.argv) > 4:
                cmd["clickAt"]["clickCount"] = int(sys.argv[4])
            r = send(sock, cmd)
        elif cmd_name == "drag":
            r = send(sock, {"dragAt": {
                "fromX": float(sys.argv[2]), "fromY": float(sys.argv[3]),
                "toX": float(sys.argv[4]), "toY": float(sys.argv[5])}})
        elif cmd_name == "press-button":
            index = int(sys.argv[3]) if len(sys.argv) > 3 else 0
            r = send(sock, {"pressButton": {"title": sys.argv[2], "index": index}})
        elif cmd_name == "ax-tree":
            cmd = {"axTree": {}}
            if len(sys.argv) > 2:
                cmd["axTree"]["maxDepth"] = int(sys.argv[2])
            r = send(sock, cmd)
        elif cmd_name == "ax-rotors":
            r = send(sock, {"axRotors": {}})
        elif cmd_name == "ax-press":
            cmd = {"axPress": {"query": sys.argv[2]}}
            if len(sys.argv) > 3:
                cmd["axPress"]["action"] = sys.argv[3]
            if len(sys.argv) > 4:
                cmd["axPress"]["index"] = int(sys.argv[4])
            r = send(sock, cmd)
        elif cmd_name == "quit":
            r = send(sock, {"quit": {}})
        else:
            print(f"Unknown command: {cmd_name}", file=sys.stderr)
            sys.exit(1)
        print(json.dumps(r, indent=2))
    except ConnectionRefusedError:
        print(f"Connection refused: {sock}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
